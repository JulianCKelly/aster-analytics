    SNOWFLAKE.CORTEX.COMPLETE('mixtral-8x7b',
        CONCAT(
            'You are a care coordinator reviewing a gap in a cross-border patient record. ',
            'This patient immigrated from ', origin_country, '. ',
            'The gap type is ', gap_type, '. ',
            'Assess: (1) patient harm risk if unaddressed, ',
            '(2) whether this gap is immigration-specific or universal, ',
            '(3) one concrete intervention. ',
            'Be concise. Format: HARM_RISK: <HIGH/MED/LOW> | TYPE: <immigration-specific/universal> | INTERVENTION: <sentence>. ',
            'Gap description: ', description
        )
    ) AS gap_analysis
FROM DBT_CORTEX_LLMS.ANALYTICS.fact_care_gaps
    )

