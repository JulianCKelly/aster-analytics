[0m00:31:39.490427 [debug] [Thread-2 (]: On model.dbt_cortex.clinical_insight_summaries: create or replace transient table DBT_CORTEX_LLMS.ANALYTICS.clinical_insight_summaries
    
    
    
    as (-- Cortex LLM: generate actionable insight summary per patient across all data
WITH labs_agg AS (
    SELECT
        patient_id,
        COUNT(CASE WHEN flag = 'H' THEN 1 END) AS abnormal_high,
        COUNT(CASE WHEN flag = 'L' THEN 1 END) AS abnormal_low,
        LISTAGG(CONCAT(test_name, ': ', result_value, ' ', unit, ' (', flag, ')'), ' | ') AS lab_summary
    FROM DBT_CORTEX_LLMS.ANALYTICS.fact_lab_results
    GROUP BY patient_id
)
SELECT
    p.patient_id,
    p.full_name,
    p.country_of_origin,
    p.insurance_status,
    l.abnormal_high,
    l.abnormal_low,
    l.lab_summary,
    SNOWFLAKE.CORTEX.COMPLETE('mixtral-8x7b',
        CONCAT(
            'You are a clinical data analyst. Generate a brief insight summary for a care coordinator. ',
            'Patient: ', p.full_name, ', from ', p.country_of_origin, '. ',
            'Insurance: ', p.insurance_status, '. ',
            'Lab results: ', COALESCE(l.lab_summary, 'none on file'), '. ',
            'Abnormal values: ', COALESCE(l.abnormal_high::VARCHAR, '0'), ' elevated, ',
            COALESCE(l.abnormal_low::VARCHAR, '0'), ' low. ',
            'In 2 sentences: what does this lab picture suggest clinically, ',
            'and what is the most important next step? Be direct.'
        )
    ) AS clinical_insight
FROM DBT_CORTEX_LLMS.STAGE.stg_patients p
LEFT JOIN labs_agg l ON p.patient_id = l.patient_id
    )

