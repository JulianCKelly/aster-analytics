    as (-- Care continuity trend analysis: cross-border gap patterns by country and type
SELECT
    origin_country,
    gap_type,
    severity,
    COUNT(*) AS gap_count,
    COUNT(CASE WHEN us_provider_aware = TRUE THEN 1 END) AS provider_aware_count,
    COUNT(CASE WHEN us_provider_aware = FALSE THEN 1 END) AS provider_unaware_count,
    COUNT(CASE WHEN status = 'Open' THEN 1 END) AS open_gaps,
    ROUND(
        COUNT(CASE WHEN us_provider_aware = FALSE THEN 1 END) * 100.0 / COUNT(*), 1
    ) AS pct_provider_unaware,
    SNOWFLAKE.CORTEX.COMPLETE('mixtral-8x7b',
        CONCAT(
            'You are a population health analyst. ',
            'For patients from ', origin_country, ', there are ', COUNT(*)::VARCHAR,
            ' care gaps of type ', gap_type, ' with severity ', severity, '. ',
            COUNT(CASE WHEN us_provider_aware = FALSE THEN 1 END)::VARCHAR,
            ' of these are unknown to the US provider. ',
            'In one sentence, describe the systemic risk this pattern represents ',
            'for cross-border patients from this country.'
        )
    ) AS trend_insight
FROM DBT_CORTEX_LLMS.ANALYTICS.fact_care_gaps
GROUP BY origin_country, gap_type, severity
    )

